# ── LLM backend (priority: Groq → Anthropic → Ollama) ───────────────────────
# Groq: free, open-source Llama 3.1 — get key at console.groq.com (recommended for GitHub Actions)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant   # or llama-3.3-70b-versatile for better accuracy

# Anthropic Claude: paid, most accurate
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama: local only, no API key needed (default when no key is set)
OLLAMA_MODEL=llama3.2

# ── Gmail (for digest emails + reply detection) ──────────────────────────────
# Your Gmail address
GMAIL_ADDRESS=kenisiaho@gmail.com

# Gmail App Password (NOT your regular Gmail password).
# How to generate:
#   1. Enable 2-Step Verification: myaccount.google.com → Security
#   2. Go to: myaccount.google.com → Security → App passwords
#   3. Choose app: Mail, device: Mac → Generate
#   4. Paste the 16-character password below (no spaces)
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Who receives the digest (defaults to GMAIL_ADDRESS if not set)
# DIGEST_RECIPIENT=kenisiaho@gmail.com

# ── Applicant info (used in auto-apply forms) ────────────────────────────────
APPLICANT_NAME=Kennedy Isiaho
APPLICANT_PHONE=+254712869569
